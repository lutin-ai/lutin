# Rust build artifacts (root and any nested cargo project)
target/
**/target/
*.rs.bk

# JS deps (bun workspace; lockfile is committed, modules are not)
node_modules/
**/node_modules/

# Local runtime state (vendor tree, per-project state, seeded workflows)
.local/

# Per-machine state outside .local/ (e.g. control-panel keypair)
/local/

# Per-machine env config (paths, addresses, secrets)
.env

# OS junk
.DS_Store
Thumbs.db

# Editor junk
*.swp
*.swo
.idea/
.vscode/
