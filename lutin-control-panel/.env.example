# lutin-control-panel — env config
#
# Copy to `.env` (in the dir you launch the binary from) and edit.
# Process env always wins over .env, so values exported in your shell
# override these.

# WS bind address.
LUTIN_CP_ADDR=127.0.0.1:7878

# Where the CP signing keypair is stored. The same dir is read by
# `lutin-cp-mint` to mint admin tokens.
LUTIN_CP_DATA_DIR=./.local/cp

# Where per-project trees live (one subdir per project, plus
# projects.toml).
LUTIN_CP_PROJECTS_ROOT=./.local/projects

# Global config tree. CP seeds the chat workflow + assistant persona
# under `<global>/.lutin/` on every launch.
LUTIN_CONFIG_ROOT=./.local
# (Or skip LUTIN_CONFIG_ROOT and set this directly:)
# LUTIN_GLOBAL_CONFIG_DIR=./.local/lutin/.lutin

# Spawn backend: `subprocess` (no Docker, points at a local binary)
# or `docker` (default — runs lutin-project:<version> in a container).
LUTIN_CP_SPAWN_BACKEND=subprocess
LUTIN_PROJECT_BINARY=./target/release/lutin-project

# Docker-only:
# LUTIN_CP_PROJECT_IMAGE=lutin-project:0.1.0
# LUTIN_CP_CONTAINER_PREFIX=lutin-project

# Tracing filter.
RUST_LOG=info
